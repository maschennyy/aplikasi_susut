# ============================================================
# .env.example — Template konfigurasi
# File INI boleh di-commit ke GitHub (tidak ada nilai asli).
# Cara pakai: copy file ini jadi .env lalu isi nilainya.
# ============================================================

DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/NAMA_DB
SECRET_KEY=isi_dengan_random_string_panjang
FLASK_DEBUG=true

# Admin pertama dibuat otomatis saat tabel user masih kosong.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_dengan_password_kuat
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.local

# Security baseline
SECURITY_REQUIRE_LOGIN=true
SESSION_COOKIE_SECURE=false
PERMANENT_SESSION_HOURS=8
MAX_UPLOAD_MB=25
MAX_IMPORT_ROWS=20000
PASSWORD_MIN_LENGTH=10
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15
UPLOAD_RATE_LIMIT=10
UPLOAD_RATE_WINDOW_MINUTES=10
